{
  "uid": "workdup-observability",
  "title": "workdup \u2014 Observability",
  "tags": [
    "workdup",
    "temporal",
    "observability"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 3,
  "editable": true,
  "graphTooltip": 1,
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "namespace",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": {
          "query": "label_values(scan_ticks_total, namespace)",
          "refId": "var"
        },
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "allValue": ".*",
        "current": {
          "text": "All",
          "value": "$__all"
        },
        "label": "namespace"
      },
      {
        "name": "scan_interval",
        "type": "textbox",
        "query": "600",
        "current": {
          "text": "600",
          "value": "600"
        },
        "label": "scan_interval (s)",
        "description": "Your scan_interval in seconds (10m=600, 30m=1800, 60m=3600). Drives the 'falling behind' threshold line on the Scan tick duration panel."
      }
    ]
  },
  "panels": [
    {
      "type": "row",
      "title": "Scanner \u2014 is the scan keeping up?",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "Scan tick duration (last, per namespace)",
      "description": "Wall-clock time of the last scan tick (gauge). One point per tick \u2014 the scan runs every scan_interval (10\u201360m), so percentiles are meaningless at this frequency; you read each tick directly. Main 'are we keeping up?' signal: compare against scan_interval (threshold line). If it approaches/crosses the interval, the scan is falling behind.",
      "id": 2,
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 1
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "scan_tick_duration_seconds{namespace=~\"$namespace\"}",
          "legendFormat": "{{namespace}}",
          "range": true,
          "instant": false,
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "vector($scan_interval)",
          "legendFormat": "scan_interval (falling-behind threshold)",
          "range": true,
          "instant": false,
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "stepAfter",
            "fillOpacity": 10,
            "showPoints": "always",
            "pointSize": 6,
            "lineWidth": 1
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byFrameRefID", "options": "B" },
            "properties": [
              { "id": "custom.drawStyle", "value": "line" },
              { "id": "custom.lineInterpolation", "value": "linear" },
              { "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [10, 10] } },
              { "id": "custom.showPoints", "value": "never" },
              { "id": "custom.fillOpacity", "value": 0 },
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }
            ]
          }
        ]
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "last",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Scan ticks (ok vs error, per 1h)",
      "description": "Count of scan ticks over a 1h window, split by result. Scans run every scan_interval (10-60m), so this uses increase() over a window >= the interval instead of per-second rate. A nonzero 'error' line is the signal (errors + Temporal RESOURCE_EXHAUSTED = throttling). Widen the window to 6h if scan_interval=60m.",
      "id": 3,
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 1
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "sum by (namespace,result) (increase(scan_ticks_total{namespace=~\"$namespace\"}[1h]))",
          "legendFormat": "{{namespace}} {{result}}",
          "range": true,
          "instant": false,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "stepAfter",
            "fillOpacity": 10,
            "showPoints": "always",
            "pointSize": 5,
            "lineWidth": 1
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "last",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Workflow throughput (per tick)",
      "description": "Work done by each scan cycle: listed = scanned via Visibility; processed = new or history-changed; updated = written to DB; skipped = unchanged. These are gauges set at the end of each tick (exact per-scan totals, not per-second rate) — one point per tick, held until the next. listed ≈ processed + skipped; the processed/listed ratio shows how much churn each scan finds.",
      "id": 4,
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 9
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "scan_workflows_listed{namespace=~\"$namespace\"}",
          "legendFormat": "listed {{namespace}}",
          "range": true,
          "instant": false,
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "scan_workflows_processed{namespace=~\"$namespace\"}",
          "legendFormat": "processed {{namespace}}",
          "range": true,
          "instant": false,
          "refId": "B"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "scan_workflows_updated{namespace=~\"$namespace\"}",
          "legendFormat": "updated {{namespace}}",
          "range": true,
          "instant": false,
          "refId": "C"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "scan_workflows_skipped{namespace=~\"$namespace\"}",
          "legendFormat": "skipped {{namespace}}",
          "range": true,
          "instant": false,
          "refId": "D"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "stepAfter",
            "fillOpacity": 10,
            "showPoints": "always",
            "pointSize": 5,
            "lineWidth": 1
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "last",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Workflows dropped (tokenization errors)",
      "description": "Count of workflows skipped because tokenization failed (a new/unhandled event variant would silently lose a workflow). Expected to be flat 0. Any bump = investigate the scanner logs (workflow_id, run_id, error) \u2014 the detailed reason lives in logs, not in a metric label (that would blow up cardinality). 'or vector(0)' keeps a green zero line so an empty panel means 'healthy', not 'no data'.",
      "id": 5,
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 9
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "sum(increase(workflows_dropped_total{namespace=~\"$namespace\"}[1h])) or vector(0)",
          "legendFormat": "dropped",
          "range": true,
          "instant": false,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "stepAfter",
            "fillOpacity": 10,
            "showPoints": "always",
            "pointSize": 5,
            "lineWidth": 1
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "last",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
    {
      "type": "timeseries",
      "title": "History fetch duration (p50/p90/p99)",
      "description": "",
      "id": 6,
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 17
