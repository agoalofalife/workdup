            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "history_fetch_duration_seconds{namespace=~\"$namespace\",quantile=\"0.9\"}",
          "legendFormat": "p90 {{namespace}}",
          "range": true,
          "instant": false,
          "refId": "B"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "history_fetch_duration_seconds{namespace=~\"$namespace\",quantile=\"0.99\"}",
          "legendFormat": "p99 {{namespace}}",
          "range": true,
          "instant": false,
          "refId": "C"
