    {
      "type": "timeseries",
      "title": "DB write errors (per 1h)",
      "description": "SQLite failed upserts over the last hour. SQLite is single-writer, so an error here = lock contention / busy_timeout exceeded / disk problem. Expected flat 0 ('or vector(0)' keeps a green zero line so empty means healthy, not 'no data'). This is the only place DB-write failures are distinguishable from other tick errors.",
      "id": 13,
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 32
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "sum(increase(db_writes_total{result=\"error\"}[1h])) or vector(0)",
          "legendFormat": "write errors",
          "range": true,
          "instant": false,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "stepAfter",
            "fillOpacity": 10,
            "showPoints": "always",
